---
import { commentConfig } from "@/config";

const twikooOptions = commentConfig.twikoo;
---

<div id="twikoo-container" class="twikoo-container">
	<div id="tcomment"></div>
</div>

<script is:inline define:vars={{ envId: twikooOptions?.envId, region: twikooOptions?.region, lang: twikooOptions?.lang }}>
	const CONTAINER_ID = "twikoo-container";
	const SCRIPT_URL = "https://cdn.jsdelivr.net/npm/twikoo@1.7.7/dist/twikoo.all.min.js";
	const ROOT_MARGIN = "200px";
	const SWUP_DELAY = 200;

	let observer = null;
	let scriptLoaded = false;

	function getCurrentPath() {
		const pathname = window.location.pathname;
		return pathname.endsWith("/") && pathname.length > 1
			? pathname.slice(0, -1)
			: pathname;
	}

	function buildTwikooConfig() {
		return {
			envId,
			...(region && { region }),
			...(lang && { lang }),
			el: "#tcomment",
			path: getCurrentPath(),
		};
	}

	function loadTwikooScript() {
		if (scriptLoaded) return Promise.resolve();
		return new Promise((resolve, reject) => {
			const script = document.createElement("script");
			script.src = SCRIPT_URL;
			script.async = true;
			script.onload = () => {
				scriptLoaded = true;
				resolve();
			};
			script.onerror = reject;
			document.head.appendChild(script);
		});
	}

	async function initTwikoo() {
		const commentEl = document.getElementById("tcomment");
		if (!commentEl) return;

		try {
			await loadTwikooScript();
			if (typeof twikoo === "undefined") {
				console.warn("[Twikoo] script failed to load");
				return;
			}
			commentEl.innerHTML = "";
			await twikoo.init(buildTwikooConfig());
		} catch (error) {
			console.error("[Twikoo] init failed:", error);
		}
	}

	function cleanup() {
		if (observer) {
			observer.disconnect();
			observer = null;
		}
		window.swup?.hooks?.off("content:replace", initTwikoo);
	}

	function setupLazyLoad() {
		const container = document.getElementById(CONTAINER_ID);
		if (!container) return;

		observer = new IntersectionObserver(
			(entries) => {
				if (entries[0].isIntersecting) {
					observer.disconnect();
					observer = null;
					initTwikoo();
				}
			},
			{ rootMargin: ROOT_MARGIN },
		);

		observer.observe(container);
	}

	function setupSwupHooks() {
		const register = () => {
			window.swup?.hooks?.on("content:replace", () => {
				setTimeout(setupLazyLoad, SWUP_DELAY);
			});
		};

		if (window.swup?.hooks) {
			register();
		} else {
			document.addEventListener("swup:enable", register, { once: true });
		}
	}

	document.addEventListener("mizuki:page:loaded", setupLazyLoad);
	window.addEventListener("beforeunload", cleanup);

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", () => {
			setupLazyLoad();
			setupSwupHooks();
		});
	} else {
		setupLazyLoad();
		setupSwupHooks();
	}
</script>

<style>
	.twikoo-container { min-height: 200px; }
</style>
